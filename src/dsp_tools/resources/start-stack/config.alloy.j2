// =============================================================================
// Grafana Alloy configuration for `dsp-tools start-stack --otlp-endpoint`.
// Rendered from this template at startup; do not edit the rendered copy by hand.
//
// Collects metrics and profiles from the local DSP stack and forwards them on:
//   1. Metrics  - dsp-api/dsp-ingest-style OTLP push is received on :4317/:4318,
//                 Fuseki metrics are scraped from db:3030/$/metrics, and both are
//                 forwarded to the OTLP/gRPC endpoint passed via --otlp-endpoint.
//   2. Profiles - the db Pyroscope agent pushes profiles to this Alloy on :4040,
//                 which forwards them to the Pyroscope endpoint (derived from the
//                 --otlp-endpoint host on port 4040).
//
// Traces and logs are dropped (they have no consumer).
// =============================================================================

// --- Source 1: OTLP receiver (db pushes its JVM/runtime metrics here) --------
otelcol.receiver.otlp "default" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    metrics = [otelcol.processor.batch.default.input]
  }
}

// --- Source 2: Fuseki Prometheus metrics -------------------------------------
prometheus.scrape "fuseki" {
  targets      = [{ "__address__" = "db:3030" }]
  metrics_path = "/$/metrics"

  // The DSP Fuseki image protects its admin endpoints with basic auth.
  basic_auth {
    username = "admin"
    password = "test"
  }

  forward_to = [otelcol.receiver.prometheus.fuseki.receiver]
}

// Bridge the scraped Prometheus metrics into the OTLP pipeline.
otelcol.receiver.prometheus "fuseki" {
  output {
    metrics = [otelcol.processor.batch.default.input]
  }
}

// --- Batching ----------------------------------------------------------------
otelcol.processor.batch "default" {
  output {
    metrics = [otelcol.exporter.otlp.external.input]
  }
}

// --- Export metrics to the external OTLP/gRPC endpoint (plaintext, no auth) ---
otelcol.exporter.otlp "external" {
  client {
    endpoint = "{{ OTLP_ENDPOINT }}"
    tls {
      insecure = true
    }
  }
}

// --- Profiles: receive from the db Pyroscope agent, forward to the host -------
pyroscope.receive_http "default" {
  http {
    listen_address = "0.0.0.0"
    listen_port    = 4040
  }
  forward_to = [pyroscope.write.external.receiver]
}

pyroscope.write "external" {
  endpoint {
    url = "{{ PYROSCOPE_ENDPOINT }}"
  }
}
